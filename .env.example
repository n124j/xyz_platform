# ============================================================
# XYZ Platform — Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# PostgreSQL
DB_NAME=xyz_platform
DB_USER=xyz_user
DB_PASSWORD=xyz_pass
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=changeme

# Apache Airflow
AIRFLOW_API_URL=http://airflow-webserver:8080/api/v1
AIRFLOW_API_USER=airflow
AIRFLOW_API_PASSWORD=airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://DB_USER:DB_PASSWORD@db/DB_NAME_airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=

# Email (production only)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=

# Sentry (production only)
SENTRY_DSN=

# S3 (optional, production)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# CORS (production)
CORS_ALLOWED_ORIGINS=https://xyz.internal.com
